# Production deploy — copy to .env in repo root and fill. NO real secrets in this file.
# Generate secrets: scripts/gen_secrets.sh (or use openssl rand -hex 24 for each).

# --- Required (no defaults in prod) ---
POSTGRES_PASSWORD=
POSTGRES_USER=gni
POSTGRES_DB=gni
JWT_SECRET=
API_KEY=
ADMIN_API_KEY=
WA_QR_BRIDGE_TOKEN=

# --- Service URLs (use defaults below or override) ---
# Must match POSTGRES_PASSWORD above
DATABASE_URL=postgresql://gni:REPLACE_ME@postgres:5432/gni
REDIS_URL=redis://redis:6379/0
OLLAMA_BASE_URL=http://ollama:11434
WHATSAPP_BOT_BASE_URL=http://whatsapp-bot:3100

# --- API ---
API_PORT=8000

# --- Collector ---
COLLECTOR_INTERVAL_MINUTES=15
INGEST_LIMIT=50
TELEGRAM_SINCE_MINUTES=60
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELETHON_SESSION_PATH=/data/telethon/session
RSS_SOURCES_PATH=
DATA_SOURCES_PATH=

# --- Worker ---
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_PULL_ON_START=true
RUN_EVERY_MINUTES=15
DRY_RUN=1
TELEGRAM_BOT_TOKEN=
TELEGRAM_TARGET_CHAT_ID=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_URL=
MAKE_WEBHOOK_URL=

# --- WhatsApp QR UI (Streamlit) ---
AUTO_REFRESH_SECONDS=3

# --- Optional ---
# BACKUP_RETENTION=7
# DEPLOY_PATH=/opt/gni-bot-creator
